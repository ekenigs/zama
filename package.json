{
  "name": "zama",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "pnpm -r typecheck",
    "typecheck": "pnpm -r typecheck",
    "test": "node --import tsx --test tests/**/*.test.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "fallow": "fallow",
    "prepare": "lefthook install",
    "db:generate": "pnpm --filter @zama-indexer/db generate",
    "db:migrate": "pnpm --filter @zama-indexer/db migrate",
    "dev": "bash scripts/dev.sh",
    "contracts:deps": "bash scripts/install-contract-deps.sh",
    "dev:api": "pnpm --filter @zama-indexer/api dev",
    "dev:worker": "pnpm --filter @zama-indexer/worker dev",
    "dev:indexer": "pnpm --filter @zama-indexer/indexer dev",
    "dev:db": "docker compose up -d postgres",
    "fund": "tsx scripts/fund.ts",
    "send": "tsx scripts/send.ts",
    "grant": "tsx scripts/grant.ts"
  },
  "dependencies": {
    "@zama-indexer/decrypt": "workspace:*",
    "@zama-indexer/env": "workspace:*",
    "commander": "15.0.0",
    "viem": "2.47.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@types/node": "25.9.3",
    "@zama-indexer/db": "workspace:*",
    "@zama-indexer/env": "workspace:*",
    "fallow": "2.99.0",
    "fastify": "5.8.2",
    "lefthook": "2.1.9",
    "tsx": "4.22.4",
    "typescript": "6.0.3"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.6.0",
      "onFail": "download"
    }
  }
}
