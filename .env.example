# Local fhEVM chain
RPC_URL=http://127.0.0.1:8545
CHAIN_ID=31337

# Deployed ERC-7984 wrapper (set by scripts/dev.sh after forge deploy)
CONTRACT_ADDRESS=

# Indexer EOA — Anvil account #1 by default
INDEXER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Postgres (database zama)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/zama

# Envio Postgres (database envio)
ENVIO_PG_HOST=127.0.0.1
ENVIO_PG_PORT=5432
ENVIO_PG_USER=postgres
ENVIO_PG_PASSWORD=postgres
ENVIO_PG_DATABASE=envio
ENVIO_PG_SCHEMA=public
ENVIO_HASURA=false
ENVIO_TUI=false

# API
API_HOST=0.0.0.0
API_PORT=3000
TOKEN_DECIMALS=6

# Worker
WORKER_POLL_INTERVAL_MS=2000
WORKER_BATCH_SIZE=50
DECRYPT_TIMEOUT_MS=5000
